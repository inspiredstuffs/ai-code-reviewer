# --- GitHub App (Settings -> Developer settings -> GitHub Apps -> your app) ---
GITHUB_APP_ID=123456
# Paste the .pem on one line, with real newlines escaped as \n
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# A long random string; must match the "Webhook secret" set on the GitHub App
GITHUB_WEBHOOK_SECRET=generate-a-long-random-string

# --- Trigger ---
# The GitHub login that, when requested as a reviewer, triggers a Claude review.
# Use your own username, or a dedicated machine-user account.
REVIEWER_LOGIN=your-github-username

# --- Claude subscription auth ---
# Generate with: claude setup-token   (valid ~1 year; bills to your Pro/Max plan)
CLAUDE_CODE_OAUTH_TOKEN=claude_oauth_xxx
# IMPORTANT: do NOT set ANTHROPIC_API_KEY here — it would take precedence and
# move usage onto metered API billing instead of your subscription.

CLAUDE_MODEL=claude-sonnet-4-6
PORT=3000
