# --- Repository provider ---
# Which code host to talk to. "github" (default) or "gitlab". One host per deploy;
# fill in only that host's block below. The webhook lands on /api/<provider>/webhooks.
REPO_PROVIDER=github

# --- GitHub App (REPO_PROVIDER=github) ---
# Settings -> Developer settings -> GitHub Apps -> your app.
GITHUB_APP_ID=123456
# Paste the .pem on one line, with real newlines escaped as \n
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# A long random string; must match the "Webhook secret" set on the GitHub App
GITHUB_WEBHOOK_SECRET=generate-a-long-random-string
# The GitHub login that, when requested as a reviewer, triggers a review. Use your
# own username, or a dedicated machine-user account. Single value or comma-separated.
REVIEWER_LOGIN=your-github-username

# --- GitLab (REPO_PROVIDER=gitlab) ---
# A Project or Group access token (scopes: api, read_repository). Its bot user is the
# account that, when added as a reviewer OR assignee on an MR, triggers a review — the
# bot identity is resolved from the token, so there's no REVIEWER_LOGIN on GitLab.
#GITLAB_TOKEN=glpat-xxx
# Must match the "Secret token" set on the project/group webhook (Merge request events).
#GITLAB_WEBHOOK_SECRET=generate-a-long-random-string
# API base; defaults to https://gitlab.com. Point at your host for self-managed GitLab.
#GITLAB_API_URL=https://gitlab.com

# --- AI provider ---
# Which review engine to drive. "claude" (the Claude Code CLI) is the default;
# "codex" drives the official @openai/codex-sdk.
AI_PROVIDER=claude

# --- Claude subscription auth ---
# Generate with: claude setup-token   (valid ~1 year; bills to your Pro/Max plan)
CLAUDE_CODE_OAUTH_TOKEN=claude_oauth_xxx
# IMPORTANT: do NOT set ANTHROPIC_API_KEY here — it would take precedence and
# move usage onto metered API billing instead of your subscription.

CLAUDE_MODEL=claude-sonnet-4-6

# --- Codex SDK auth/config (AI_PROVIDER=codex) ---
# @openai/codex-sdk is installed as an app dependency. CODEX_API_KEY takes precedence
# when set. Otherwise Codex uses CODEX_HOME cached CLI auth/config or
# CODEX_ACCESS_TOKEN. CODEX_ACCESS_TOKEN is the Codex/ChatGPT access-token mode
# for trusted automation (OAuth-style subscription/workspace identity), analogous
# operationally to providing CLAUDE_CODE_OAUTH_TOKEN for Claude. If none are set,
# the host/container must already be logged in at ~/.codex with `codex login`.
#CODEX_MODEL=gpt-5.5
#CODEX_HOME=/home/app/.codex
#CODEX_API_KEY=sk-...
#CODEX_ACCESS_TOKEN=codex_access_token
PORT=3000

# Display name shown in the review header ("🤖 **<BOT_NAME> review**") and the
# failure notice. Defaults to "Alátùńwò AI" — override to rebrand.
BOT_NAME=Alátùńwò AI

# --- Review store (SQLite) ---
# Where the idempotency + audit-log database lives. Defaults to ./data/reviews.db.
# In a container, point this at a mounted volume so it survives redeploys
# (config/deploy.yml sets it to /data/reviews.db).
DATABASE_PATH=./data/reviews.db

# --- Deep reviews (optional) ---
# When "true", the service clones the PR/MR head and lets the model open surrounding
# files (read-only tools only — no shell/write). Needs git on the host and read access
# to repo contents (GitHub App Contents: Read / GitLab token read_repository). Off by
# default (diff-only). Either way, a PR/MR labelled "deep-review" always gets a deep
# review. DEEP_REVIEW_MAX_TURNS is the turn budget per deep review; diff-only reviews
# always use a single pass.
DEEP_REVIEW=false
DEEP_REVIEW_MAX_TURNS=8
