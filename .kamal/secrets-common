# Reference-only: every value is resolved from the shell environment at deploy
# time. No real secrets live in this file. Kamal does NOT auto-load `.env`, so
# export the values into your shell first, e.g.:
#   set -a; source .env; set +a; kamal setup
# (In CI, the runner injects these as env vars directly.)
KAMAL_REGISTRY_USERNAME=$KAMAL_REGISTRY_USERNAME
KAMAL_REGISTRY_PASSWORD=$KAMAL_REGISTRY_PASSWORD
# GitHub provider (REPO_PROVIDER=github) — empty/harmless on a GitLab deploy.
GITHUB_APP_ID=$GITHUB_APP_ID
GITHUB_APP_PRIVATE_KEY=$GITHUB_APP_PRIVATE_KEY
GITHUB_WEBHOOK_SECRET=$GITHUB_WEBHOOK_SECRET
REVIEWER_LOGIN=$REVIEWER_LOGIN
# GitLab provider (REPO_PROVIDER=gitlab) — empty/harmless on a GitHub deploy.
GITLAB_TOKEN=$GITLAB_TOKEN
GITLAB_WEBHOOK_SECRET=$GITLAB_WEBHOOK_SECRET
CLAUDE_CODE_OAUTH_TOKEN=$CLAUDE_CODE_OAUTH_TOKEN
REPO_PROVIDER=$REPO_PROVIDER
