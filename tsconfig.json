{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "server.ts",
    "provider.ts",
    "repository.ts",
    "review.ts",
    "clone.ts",
    "store.ts",
    "providers/**/*.ts",
    "repositories/**/*.ts",
    "test/**/*.ts"
  ]
}
