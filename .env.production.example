# Deploy-time env for `bin/kamal -d production ...`.
# Copy to `.env.production` (gitignored) and fill in real values. `bin/kamal`
# sources this with `set -a`, so Kamal's secrets-common can resolve the $VAR
# references and deploy.yml's ERB can read WEB_HOSTS / PROXY_HOST.

# --- GitHub Container Registry (ghcr.io) ---
# Image repo under ghcr.io: "<ghcr-namespace>/<name>" (the registry host is added
# by deploy.yml). The namespace is your GitHub user or org; pick any image name.
IMAGE=your-ghcr-namespace/ai-code-reviewer
# Username = the GitHub account that owns the PAT (your personal login, or the org
# if the PAT is org-scoped). May differ from the image namespace.
KAMAL_REGISTRY_USERNAME=your-github-username
# A GitHub PAT with the write:packages scope.
KAMAL_REGISTRY_PASSWORD=ghp_xxx

# --- Target server ---
# Comma-separated Hetzner IPs/hosts.
WEB_HOSTS=1.2.3.4
# Public hostname Kamal's proxy serves over HTTPS (needs a DNS A record -> WEB_HOSTS).
PROXY_HOST=reviewer.example.com
# SSH user on the server (defaults to "deploy").
SSH_USER=deploy

# --- Repository provider ---
# Which code host to talk to: "github" (default) or "gitlab". Fill in only the
# matching block below. deploy.yml supplies "github" if unset.
#REPO_PROVIDER=github

# --- App secrets (injected into the container by Kamal) ---
# GitHub (REPO_PROVIDER=github):
GITHUB_APP_ID=123456
# base64 of the .pem (recommended — survives shell + env-file layers cleanly):
#   base64 < your-app.private-key.pem | tr -d '\n'
# A raw PEM or a \n-escaped one-liner also works; the app auto-detects the format.
GITHUB_APP_PRIVATE_KEY=LS0tLS1CRUdJTiBSU0EgUF...base64...
GITHUB_WEBHOOK_SECRET=generate-a-long-random-string
# GitHub login(s) whose review-request triggers a review. Single value or a
# comma-separated list, e.g. "your-github-username" or "user-a,user-b".
REVIEWER_LOGIN=your-github-username

# GitLab (REPO_PROVIDER=gitlab) — Project/Group access token (scopes: api,
# read_repository); the bot is triggered when added as a reviewer or assignee.
#GITLAB_TOKEN=glpat-xxx
#GITLAB_WEBHOOK_SECRET=generate-a-long-random-string
#GITLAB_API_URL=https://gitlab.com

# From `claude setup-token` — bills to your subscription. NEVER set ANTHROPIC_API_KEY.
CLAUDE_CODE_OAUTH_TOKEN=claude_oauth_xxx

# --- Optional tunables (deploy.yml supplies these defaults if unset) ---
# Which code host to talk to; "github" is the default. See REPO_PROVIDER above.
#REPO_PROVIDER=github
# Which review engine to drive; "claude" is the default and only provider today.
#AI_PROVIDER=claude
# Override the model.
#CLAUDE_MODEL=claude-sonnet-4-6
# Display name in the review header/notice.
#BOT_NAME=Alátùńwò AI

# --- Deep reviews (optional) ---
# When "true", the service clones the PR/MR head and lets the model open surrounding
# files (read-only tools only — no shell/write). Needs git on the host and read access
# to repo contents (GitHub App Contents: Read / GitLab token read_repository). Off by
# default (diff-only). Either way, a PR/MR labelled "deep-review" always gets a deep
# review. DEEP_REVIEW_MAX_TURNS is the turn budget per deep review; diff-only reviews
# always use a single pass.
DEEP_REVIEW=false
DEEP_REVIEW_MAX_TURNS=8
